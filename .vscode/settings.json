{
  // ----- Python interpreter -----
  // Use the uv-managed venv. VS Code / Cursor will auto-select this once `make install` has run.
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.terminal.activateEnvironment": true,
  "python.terminal.activateEnvInCurrentTerminal": true,
  "python.analysis.extraPaths": ["${workspaceFolder}/src"],
  "python.analysis.typeCheckingMode": "basic",
  "python.testing.pytestEnabled": false,

  // ----- Formatting (matches pyproject.toml: black line-length 120, isort) -----
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },
  "black-formatter.args": ["--line-length=120"],
  "isort.args": ["--profile=black", "--line-length=120"],

  // ----- Notebooks (.ipynb) -----
  // Use the same `vn1` kernel registered by `make install`.
  "jupyter.notebookFileRoot": "${workspaceFolder}",
  "jupyter.kernels.excludePythonEnvironments": [],
  "notebook.defaultFormatter": "ms-python.black-formatter",
  "notebook.formatOnSave.enabled": true,
  "notebook.lineNumbers": "on",
  "notebook.output.scrolling": true,
  "notebook.output.textLineLimit": 200,

  // ----- Editor sanity -----
  "editor.rulers": [120],
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,

  // ----- Hide noise from the explorer / search -----
  "files.exclude": {
    "**/__pycache__": true,
    "**/.ipynb_checkpoints": true,
    "**/.pytest_cache": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true,
    "**/*.egg-info": true
  },
  "search.exclude": {
    "**/.venv": true,
    "**/uv.lock": true,
    "**/__pycache__": true
  }
}
