# Copy to .openrouter/.env (which should be gitignored) and fill in.
# Or, preferred: keep the key in Bitwarden as `agent.openrouter.api_key`
# and let your agent fetch it at runtime.

OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional — name your client so OpenRouter's dashboard groups requests:
# OPENROUTER_HTTP_REFERER=https://your.domain
# OPENROUTER_X_TITLE=__REPO_NAME__
